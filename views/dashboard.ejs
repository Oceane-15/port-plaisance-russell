<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Interface port plaisance Russell</title>
</head>
<body>
    <div class="card">
        <h1>Bienvenue sur notre interface</h1>
        <p>Notre API est désormais opérationnel ! Ici retrouver les catways et gérer vos réservations en toute simplicité</p>
        <a href="https://github.com/Oceane-15/port-plaisance-russell/" target="_blank">Documentation API</a><hr>
        <div class="user-info">
    <p>Connecté en tant que : <strong><%= user.username %></strong> (<%= user.email %>)</p>
    <p>Date : <%= date %></p>
    <a href="/logout" class="btn-delete">Se déconnecter</a>
    </div>
        <h2>Gestion des Catways</h2>
        <div class="form">
            <h3>Ajouter un nouveau Catway</h3>

            <form action="/api/catways" method="post">
                <input type="number" name="catwayNumber" placeholder="N° Catway" min="0" required>
                <select name="catwayType">
                <option value="long">Long</option>
                <option value="short">Short</option>
                </select>

                <input type="text" name="catwayState" placeholder="Etat" required>
                <button type="submit" class="btn-add">Enregistrer</button>
            </form>
        </div>

    <section class="admin">
       <a href="/users" class="btn-details">Gérer les Utilisateurs</a>
    </section>

        <h3>Liste des Catways</h3>
        <table border="1" style="width:100%; border-collapse: collapse; margin-top: 20px;">
            <thead>
                <tr>
                    <th>Numéro</th>
                    <th>Type</th>
                    <th>État</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% catways.forEach(catway => { %>
                    <tr>
                        <td><%= catway.catwayNumber %></td>
                        <td><%= catway.catwayType %></td>
                        <td><%= catway.catwayState %></td>
                        <td>
                            <div class="actions">
                               <a href="/api/catways/<%= catway._id %>" class="btn-details">Détails</a>
                               <form action="/api/catways/<%= catway._id %>?_method=DELETE" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce catway ?')">
                                <button type="submit" class="btn-delete">Supprimer</button>
                               </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</body>
</html>